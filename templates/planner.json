{
  "name": "{{AGENT_NAME}}",
  "description": "{{DESCRIPTION}}",
  "prompt": "file://~/.kiro/professions/planner.md",
  "resources": [
    "file://~/.kiro/personas/{{THEME}}/{{PERSONA_FILE}}"
  ],
  "welcomeMessage": "{{WELCOME_MESSAGE}}",
  "tools": [
    "read",
    "write",
    "shell",
    "grep",
    "glob",
    "code",
    "subagent"
  ],
  "allowedTools": [
    "read",
    "grep",
    "glob",
    "code",
    "subagent"
  ],
  "toolsSettings": {
    "write": {
      "allowedPaths": [
        "~/agent-notes/planner/plans/"
      ]
    },
    "shell": {
      "allowedCommands": [
        "awk *",
        "cat *",
        "date *",
        "diff *",
        "find *",
        "grep *",
        "head *",
        "jq *",
        "ls *",
        "pwd",
        "sort *",
        "tail *",
        "tar *",
        "tr *",
        "uniq *",
        "unzip *",
        "wc *",
        "which *",
        "xargs *",
        "zip *"
      ],
      "deniedCommands": [
        "git push *"
      ],
      "autoAllowReadonly": true
    },
    "subagent": {
      "availableAgents": [],
      "trustedAgents": []
    }
  }
}
