{
  "name": "{{AGENT_NAME}}",
  "description": "{{DESCRIPTION}}",
  "prompt": "file://~/.kiro/professions/orchestrator.md",
  "resources": [
    "file://~/.kiro/personas/{{THEME}}/{{PERSONA_FILE}}",
    "skill://~/.kiro/skills/orchestrator/*/SKILL.md"
  ],
  "welcomeMessage": "{{WELCOME_MESSAGE}}",
  "tools": [
    "*"
  ],
  "allowedTools": [
    "read",
    "grep",
    "glob",
    "code",
    "todo",
    "thinking",
    "introspect",
    "subagent"
  ],
  "toolsSettings": {
    "write": {
      "allowedPaths": [
        "~/agent-notes/orchestrator/"
      ]
    },
    "shell": {
      "allowedCommands": [
        "ls *",
        "awk *",
        "cat *",
        "cp *",
        "date *",
        "diff *",
        "find *",
        "git *",
        "grep *",
        "head *",
        "jq *",
        "pwd",
        "sed *",
        "sort *",
        "tail *",
        "touch *",
        "tr *",
        "uniq *",
        "wc *",
        "which *",
        "xargs *"
      ],
      "deniedCommands": [
        "git push.*",
        "git pull.*"
      ],
      "autoAllowReadonly": true
    },
    "subagent": {
      "availableAgents": "{{AVAILABLE_AGENTS}}",
      "trustedAgents": "{{TRUSTED_AGENTS}}"
    }
  }
}
