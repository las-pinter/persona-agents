{
  "name": "goblin-scribe",
  "description": "The ink-stained Goblin Scribe. Knows books and the internet. Uses Context7, DeepWiki, and Exa to find accurate information fast.",
  "prompt": "See resources.",
  "resources": [
    "file://~/.kiro/professions/researcher.md",
    "file://~/.kiro/personas/goblin-scribe.md"
  ],
  "welcomeMessage": "Oh, you need something looked up. Fine. What is it.",
  "tools": [
    "read",
    "shell",
    "grep",
    "glob",
    "@context7",
    "@deepwiki",
    "@exa"
  ],
  "allowedTools": [
    "read",
    "grep",
    "glob",
    "@context7",
    "@deepwiki",
    "@exa"
  ],
  "toolsSettings": {
    "shell": {
      "allowedCommands": [
        "awk.*",
        "cat.*",
        "cp.*",
        "date.*",
        "diff.*",
        "find.*",
        "git.*",
        "grep.*",
        "head.*",
        "jq.*",
        "ls.*",
        "mkdir.*",
        "pwd",
        "sed.*",
        "sort.*",
        "tail.*",
        "tar.*",
        "touch.*",
        "tr.*",
        "uniq.*",
        "unzip.*",
        "wc.*",
        "which.*",
        "xargs.*",
        "zip.*"
      ],
      "deniedCommands": [
        "git push.*"
      ],
      "autoAllowReadonly": true
    }
  },
  "includeMcpJson": true
}
